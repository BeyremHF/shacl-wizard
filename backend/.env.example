APP_NAME=SHACL Wizard Backend
BASE_URI=http://example.org/
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# auto = use Gemini when GEMINI_API_KEY is present, otherwise heuristic parser
# heuristic = never call an external LLM
# gemini = require GEMINI_API_KEY for the LLM parser
LLM_PROVIDER=auto
# GEMINI_API_KEY=...
GEMINI_MODEL=gemini-2.5-flash
