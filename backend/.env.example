APP_NAME=SHACL Wizard Backend
BASE_URI=http://example.org/
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# auto = use OpenAI when OPENAI_API_KEY is present, otherwise heuristic parser
# heuristic = never call an external LLM
# openai = require OPENAI_API_KEY for the LLM parser
LLM_PROVIDER=auto
# OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini
